{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "refresh": "5s",
  "schemaVersion": 42,
  "style": "dark",
  "tags": [],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Claims Processor Observability",
  "uid": "claims-processor",
  "version": 1,
  "panels": [

    {
      "id": 1,
      "title": "Heap Usage Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"claims-app\"}",
          "legendFormat": "Heap Memory",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Container Restart Count",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "changes(container_start_time_seconds{job=\"cadvisor\"} [10m])",
          "legendFormat": "Restarts (10m)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Request Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"claims-app\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"claims-app\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"claims-app\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 4,
      "title": "Log Error Rate (errors/sec)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate({container=\"claims-app\"} |= \"ERROR\" [1m])",
          "legendFormat": "Logs/sec",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "SLO Compliance (99.5% threshold)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "(sum(rate(http_request_duration_seconds_bucket{job=\"claims-app\",le=\"2.0\"}[5m])) / sum(rate(http_request_duration_seconds_count{job=\"claims-app\"}[5m]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    }

  ]
}